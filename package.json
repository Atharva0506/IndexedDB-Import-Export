{
  "name": "@aossie-org/idb-backup",
  "version": "1.0.0",
  "description": "A framework-agnostic, lightweight TypeScript library for exporting and importing IndexedDB databases via type-tagged JSON.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "indexeddb",
    "backup",
    "export",
    "import",
    "idb",
    "json",
    "browser",
    "typescript"
  ],
  "author": "AOSSIE",
  "license": "GPL-3.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AOSSIE-Org/IndexedDB-Import-Export.git"
  },
  "bugs": {
    "url": "https://github.com/AOSSIE-Org/IndexedDB-Import-Export/issues"
  },
  "homepage": "https://github.com/AOSSIE-Org/IndexedDB-Import-Export#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "idb": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "fake-indexeddb": "^6.0.0"
  }
}
